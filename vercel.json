{
    "version": 2,
    "builds": [
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api",
            "dest": "https://converta-drv.onrender.com/api"
        },
        {
            "src": "/api/(.*)",
            "dest": "https://converta-drv.onrender.com/api/$1"
        },
        {
            "src": "/download/(.*)",
            "dest": "https://converta-drv.onrender.com/download/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}
